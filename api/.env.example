# ---- Servidor ----
CB_HOST=0.0.0.0
CB_PORT=8000

# ---- Google AI Studio (Gemini API) ----
# Chave necessária para o LLM/ingestão multimodal (gemini-3.1-flash-lite).
# Gere em https://aistudio.google.com/apikey
CB_GOOGLE_API_KEY=

# ---- OpenAI ----
# Chave necessária para os embeddings (text-embedding-3-large).
# Gere em https://platform.openai.com/api-keys
CB_OPENAI_API_KEY=

# ---- Hugging Face ----
# Token usado apenas pelo modelo local (Whisper STT). Opcional;
# gere em https://huggingface.co/settings/tokens se necessário.
CB_HF_TOKEN=
CB_HF_CACHE_DIR=.hf_cache

# ---- Modelos ----
# LLM/ingestão multimodal via Google AI Studio (texto + imagem); precisa ser
# multimodal pois o mesmo modelo faz OCR/descrição de imagens na ingestão
CB_LLM_MODEL=gemini-3.1-flash-lite
# Embeddings via OpenAI (text-embedding-3-large = 3072 dims)
CB_EMBED_MODEL=text-embedding-3-large
# Dimensão dos embeddings: vazio = nativa (3072). Defina menor (ex.: 1024) para
# encurtar via parâmetro `dimensions` da API (troca acurácia por vetor menor).
CB_EMBED_DIMENSIONS=
# Tamanho do lote por requisição à API de embeddings
CB_EMBED_BATCH_SIZE=100
# STT (transcrição de áudio): Whisper multilíngue (99 idiomas, inclui PT-BR)
CB_STT_MODEL=openai/whisper-large-v3-turbo
# Idioma forçado da transcrição ("portuguese", "english", ...); vazio = autodetecta
CB_STT_LANGUAGE=
# Chunking do STT: 0 = long-form nativo do Whisper (timestamps precisos por
# segmento, recomendado); >0 = janela deslizante (mais rápida em áudios muito
# longos, porém timestamps grosseiros)
CB_STT_CHUNK_LENGTH_S=0
# Device do modelo LOCAL (Whisper STT): "auto", "cuda" (NVIDIA ou AMD ROCm),
# "rocm" (alias de cuda), "mps" (Apple) ou "cpu". (Embeddings rodam na OpenAI.)
CB_DEVICE=auto

# Limite de tokens gerados pelo LLM (max_output_tokens na API). Mantenha alto:
# o gemini-3.1-flash-lite sempre raciocina e o raciocínio consome tokens antes da
# resposta; um teto baixo termina em MAX_TOKENS (erro no wrapper).
CB_MAX_NEW_TOKENS=2048

# ---- Ingestão de documentos ----
# DPI ao rasterizar páginas de PDF (pdf2image) para OCR via Gemini
CB_PDF_DPI=200
# Caminho dos binários do poppler (pdftoppm/pdfinfo); vazio se já está no PATH.
# Windows: baixe em https://github.com/oschwartz10612/poppler-windows e aponte
# para a pasta .../Library/bin
CB_POPPLER_PATH=

# ---- ChromaDB (persistência local) ----
CB_CHROMA_PATH=./chroma_db
CB_CHROMA_COLLECTION=company_brain

# ---- RAG ----
CB_CHUNK_SIZE=1024
CB_CHUNK_OVERLAP=128
CB_SIMILARITY_TOP_K=8

# Diretório onde uploads multimodais são salvos temporariamente
CB_UPLOAD_DIR=./data/uploads
