# ---- Servidor ----
CB_HOST=0.0.0.0
CB_PORT=8000

# ---- Hugging Face ----
# Token necessário para baixar google/gemma-4-E2B-it (modelo gated).
# Gere em https://huggingface.co/settings/tokens e aceite a licença do modelo.
CB_HF_TOKEN=
CB_HF_CACHE_DIR=.hf_cache

# ---- Modelos ----
CB_LLM_MODEL=google/gemma-4-E2B-it
CB_EMBED_MODEL=microsoft/harrier-oss-v1-0.6b
# Dispositivo: "auto", "cuda", "cpu" ou "mps"
CB_DEVICE=auto
# dtype: "auto", "bfloat16", "float16", "float32"
CB_DTYPE=auto

# Habilita o modo de raciocínio (thinking) do Gemma 4
CB_ENABLE_THINKING=false
CB_MAX_NEW_TOKENS=1024

# ---- ChromaDB (persistência local) ----
CB_CHROMA_PATH=./chroma_db
CB_CHROMA_COLLECTION=company_brain

# ---- RAG ----
CB_CHUNK_SIZE=1024
CB_CHUNK_OVERLAP=128
CB_SIMILARITY_TOP_K=4

# Diretório onde uploads multimodais são salvos temporariamente
CB_UPLOAD_DIR=./data/uploads
